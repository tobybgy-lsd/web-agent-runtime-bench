{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tobybgy-lsd/web-agent-runtime-bench/schemas/knowledge_pattern.schema.json",
  "title": "Agent Failure Doctor Knowledge Pattern",
  "type": "object",
  "required": [
    "id",
    "version",
    "title",
    "applies_to",
    "failure_layer",
    "technical_category",
    "subtype",
    "evidence_patterns",
    "positive_evidence",
    "negative_evidence",
    "fix_plan",
    "fix_plan_template",
    "verification",
    "verification_strategy",
    "safety",
    "source_type",
    "public_safe",
    "contains_private_solution"
  ],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": ["integer", "string"] },
    "title": { "type": "string" },
    "applies_to": { "type": "array", "items": { "type": "string" } },
    "failure_layer": { "type": "string" },
    "technical_category": { "type": "string" },
    "subtype": { "type": "string" },
    "evidence_patterns": { "type": "array", "items": { "type": "string" } },
    "positive_evidence": { "type": "array", "items": { "type": "string" } },
    "negative_evidence": { "type": "array", "items": { "type": "string" } },
    "fix_plan": { "type": "object" },
    "fix_plan_template": { "type": "object" },
    "verification": { "type": "object" },
    "verification_strategy": { "type": "object" },
    "safety": { "type": "object" },
    "source_type": {
      "type": "string",
      "enum": ["local_synthetic", "public_inspired", "internal_fixture"]
    },
    "public_safe": { "const": true },
    "contains_private_solution": { "const": false }
  }
}
