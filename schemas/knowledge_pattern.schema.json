{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Failure Doctor Knowledge Pattern",
  "type": "object",
  "required": [
    "id",
    "version",
    "applies_to",
    "failure_layer",
    "technical_category",
    "subtype",
    "evidence_patterns",
    "positive_evidence",
    "negative_evidence",
    "fix_plan",
    "verification",
    "safety"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "version": { "type": "integer", "minimum": 1 },
    "applies_to": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "failure_layer": { "type": "string" },
    "technical_category": { "type": "string" },
    "subtype": { "type": "string" },
    "evidence_patterns": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "positive_evidence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "negative_evidence": { "type": "array", "items": { "type": "string" } },
    "fix_plan": {
      "type": "object",
      "required": ["intent", "recommended_change_areas"],
      "properties": {
        "intent": { "type": "string" },
        "recommended_change_areas": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "verification": {
      "type": "object",
      "required": ["expected_evidence_to_disappear", "expected_evidence_to_appear"],
      "properties": {
        "expected_evidence_to_disappear": { "type": "array", "items": { "type": "string" } },
        "expected_evidence_to_appear": { "type": "array", "items": { "type": "string" } }
      }
    },
    "safety": {
      "type": "object",
      "required": ["anti_bot", "forbidden_actions"],
      "properties": {
        "anti_bot": { "type": "boolean" },
        "forbidden_actions": { "type": "array", "items": { "type": "string" } },
        "safe_next_action_only": { "type": "boolean" }
      }
    }
  }
}
